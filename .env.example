# 複製這個檔案為 .env，填入你的真實設定
# cp .env.example .env

# ── AWS S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=你的AWS金鑰ID
AWS_SECRET_ACCESS_KEY=你的AWS秘密金鑰
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=你的bucket名稱
S3_PRICE_PREFIX=price/
S3_FEATURE_PREFIX=feature/
S3_DECISION_PREFIX=decision/

# ── 即時報價 API ─────────────────────────────────────────
TIINGO_API_KEY=你的Tiingo金鑰
FINMIND_API_KEY=你的FinMind金鑰

# ── 開發模式 ─────────────────────────────────────────────
# true = 使用假資料，false = 使用真實 S3 資料
USE_MOCK_DATA=true

# ── Dashboard 設定 ───────────────────────────────────────
DRAWDOWN_ALERT_THRESHOLD=-0.15
LIVE_PRICE_CACHE_TTL=300
